<view class="page-shell">
  <view class="hero-card">
    <text class="eyebrow">取件服务</text>
    <text class="hero-title">手机号取件</text>
    <text class="hero-subtitle">请先查询待取件订单，再前往柜机输入取件码完成取件。</text>
    <view class="hero-meta">
      <text>取件码仅用于本人取件，请妥善保管</text>
    </view>
  </view>

  <view wx:if="{{errorMessage}}" class="notice-card error">
    <text class="notice-title">暂时无法完成取件</text>
    <text class="notice-body">{{errorMessage}}</text>
  </view>

  <view class="input-card">
    <view class="section-head">
      <text class="section-title">查询待取件信息</text>
      <text class="section-subtitle">按手机号查询待取件订单</text>
    </view>

    <text class="input-label">预留手机号</text>
    <input
      class="text-input"
      type="number"
      maxlength="11"
      placeholder="请输入存件时登记的手机号"
      value="{{phone}}"
      bindinput="handlePhoneInput"
    />
    <text class="helper-text">查询到订单后，请前往柜机输入 6 位取件码完成取件。</text>

    <view class="btn-stack take-actions">
      <button class="primary-btn" bindtap="submitLookup" loading="{{lookupLoading}}" disabled="{{lookupLoading}}">查询待取件</button>
    </view>
  </view>

  <view wx:if="{{lookupResult}}" class="result-card">
    <view class="section-head">
      <text class="section-title">待取件信息</text>
      <text class="section-subtitle">请前往柜机输入取件码完成取件</text>
    </view>

    <view class="pickup-code-panel">
      <text class="code-label">6 位取件码</text>
      <text class="code-value">{{lookupResult.pickupCode}}</text>
    </view>

    <view class="inline-row">
      <text>用户手机号</text>
      <text>{{lookupResult.maskedPhone}}</text>
    </view>
    <view class="inline-row">
      <text>柜体编号</text>
      <text>{{lookupResult.cabinetNo}}</text>
    </view>
    <view class="inline-row">
      <text>存件时间</text>
      <text>{{lookupResult.createdAtText}}</text>
    </view>

    <text class="helper-text">{{lookupResult.instruction}}</text>

    <view class="btn-stack">
      <button class="primary-btn" bindtap="resetFlow">查询其他手机号</button>
      <button class="ghost-btn" bindtap="goHome">返回首页</button>
    </view>
  </view>
</view>
