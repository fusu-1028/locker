<view class="page-shell">
  <view class="hero-card">
    <text class="eyebrow">智能快递柜服务</text>
    <text class="hero-title">智能快递柜</text>
    <text class="hero-subtitle">支持存件、取件查询和业务状态查看，帮助用户快速完成寄存服务。</text>
    <view class="hero-meta">
      <text>请根据页面提示完成存件或取件操作</text>
      <text>最近刷新：{{refreshedAt}}</text>
    </view>
  </view>

  <view wx:if="{{errorMessage}}" class="notice-card error">
    <text class="notice-title">服务连接异常</text>
    <text class="notice-body">{{errorMessage}}</text>
  </view>

  <view class="summary-grid">
    <view wx:for="{{summaryCards}}" wx:key="label" class="summary-card {{item.accent}}">
      <text class="summary-label">{{item.label}}</text>
      <text class="summary-value">{{item.value}}</text>
    </view>
  </view>

  <view class="panel-card">
    <view class="section-head">
      <text class="section-title">当前柜体</text>
      <text class="section-subtitle">实时展示柜门是否可用</text>
    </view>

    <view class="locker-banner {{cabinet.statusClass}}">
      <view class="locker-banner-head">
        <text class="locker-no">柜体 {{cabinet.cabinetNo}}</text>
        <text class="chip {{cabinet.statusClass}}">{{cabinet.statusText}}</text>
      </view>
      <text class="locker-desc">空闲状态可直接发起存件；如存在待处理订单，请按提示完成当前业务。</text>
    </view>

    <view wx:if="{{cabinet.hasParcel}}" class="parcel-brief">
      <view class="inline-row">
        <text>当前订单手机号</text>
        <text>{{cabinet.parcel.maskedPhone}}</text>
      </view>
      <view class="inline-row">
        <text>当前取件码</text>
        <text class="mono-text">{{cabinet.parcel.pickupCode}}</text>
      </view>
      <view class="inline-row">
        <text>创建时间</text>
        <text>{{cabinet.parcel.createdAtText}}</text>
      </view>
    </view>

    <view wx:else class="empty-state">
      当前柜体空闲，可以办理存件业务。
    </view>
  </view>

  <view class="panel-card">
    <view class="section-head">
      <text class="section-title">快捷操作</text>
      <text class="section-subtitle">请选择需要办理的业务</text>
    </view>
    <view class="btn-stack">
      <button class="primary-btn" bindtap="goStore">我要存件</button>
      <button class="secondary-btn" bindtap="goTake">我要取件</button>
      <button class="ghost-btn" bindtap="goRecords">查看记录</button>
    </view>
  </view>

  <view class="panel-card">
    <view class="section-head">
      <text class="section-title">最近记录</text>
      <text class="section-subtitle">查看近期业务状态</text>
    </view>

    <view wx:if="{{recentRecords.length}}">
      <view wx:for="{{recentRecords}}" wx:key="id" class="activity-item">
        <view class="activity-top">
          <text class="chip {{item.actionClass}}">{{item.actionText}}</text>
          <text class="activity-time">{{item.createdAtText}}</text>
        </view>
        <text class="activity-main">{{item.maskedPhone}} · 柜体 {{item.cabinetNo}} · 取件码 {{item.pickupCode}}</text>
        <text class="activity-note">{{item.note}}</text>
      </view>
    </view>

    <view wx:else class="empty-state">
      暂无业务记录，可先办理存件或取件。
    </view>
  </view>

  <view class="panel-card">
    <view class="section-head">
      <text class="section-title">使用说明</text>
      <text class="section-subtitle">办理业务前请先了解流程</text>
    </view>
    <view wx:for="{{flowSteps}}" wx:key="*this" class="flow-item">
      <text class="flow-index">{{index + 1}}</text>
      <text class="flow-text">{{item}}</text>
    </view>
  </view>
</view>
