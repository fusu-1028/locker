.locker-banner {
  padding: 24rpx;
  border-radius: 24rpx;
  margin-bottom: 18rpx;
}

.locker-banner.idle {
  background: linear-gradient(145deg, #def6f0, #f4fcfa);
}

.locker-banner.occupied {
  background: linear-gradient(145deg, #ffe7d4, #fff6ef);
}

.locker-banner-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.locker-no {
  font-size: 34rpx;
  font-weight: 700;
  color: #173042;
}

.locker-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5f7a8d;
}

.parcel-brief {
  padding-top: 6rpx;
}

.activity-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(18, 49, 74, 0.08);
}

.activity-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.activity-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.activity-time {
  font-size: 22rpx;
  color: #7790a3;
}

.activity-main {
  display: block;
  margin-top: 14rpx;
  font-size: 28rpx;
  color: #173042;
  line-height: 1.6;
}

.activity-note {
  display: block;
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #6f8698;
}

.flow-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(18, 49, 74, 0.08);
}

.flow-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.flow-index {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 42rpx;
  font-size: 22rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #103b5e, #1c7390);
}

.flow-text {
  flex: 1;
  font-size: 25rpx;
  line-height: 1.7;
  color: #25465a;
}
