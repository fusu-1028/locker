<view class="page-shell">
  <view class="hero-card">
    <text class="eyebrow">存件服务</text>
    <text class="hero-title">手机号存件</text>
    <text class="hero-subtitle">请输入收件手机号，系统将生成取件码并引导完成存件操作。</text>
    <view class="hero-meta">
      <text>请先确认柜体可用后再发起存件</text>
    </view>
  </view>

  <view wx:if="{{errorMessage}}" class="notice-card error">
    <text class="notice-title">暂时无法完成存件</text>
    <text class="notice-body">{{errorMessage}}</text>
  </view>

  <view class="panel-card">
    <view class="section-head">
      <text class="section-title">柜体状态</text>
      <text class="section-subtitle">请确认柜门处于可用状态</text>
    </view>
    <view class="inline-row">
      <text>柜体状态</text>
      <text class="chip {{cabinet.statusClass}}">{{cabinet.statusText}}</text>
    </view>
    <view wx:if="{{cabinet.parcel}}" class="inline-row">
      <text>当前订单手机号</text>
      <text>{{cabinet.parcel.maskedPhone}}</text>
    </view>
    <view wx:if="{{cabinet.parcel}}" class="inline-row">
      <text>当前取件码</text>
      <text class="mono-text">{{cabinet.parcel.pickupCode}}</text>
    </view>
    <text class="helper-text">如果当前柜体不是空闲状态，请先完成已有订单后再发起新的存件。</text>
  </view>

  <view class="input-card">
    <view class="section-head">
      <text class="section-title">填写手机号</text>
      <text class="section-subtitle">用于生成取件码和后续查询</text>
    </view>

    <text class="input-label">手机号</text>
    <input
      class="text-input"
      type="number"
      maxlength="11"
      placeholder="请输入 11 位手机号"
      value="{{phone}}"
      bindinput="handlePhoneInput"
    />
    <text class="helper-text">请准确填写收件手机号，并提醒用户妥善保管取件码。</text>

    <view class="btn-stack store-actions">
      <button class="primary-btn" bindtap="submitStore" loading="{{submitting}}" disabled="{{submitting}}">提交存件</button>
    </view>
  </view>

  <view wx:if="{{result}}" class="result-card">
    <view class="section-head">
      <text class="section-title">{{result.confirmed ? '存件完成' : result.statusText}}</text>
      <text class="section-subtitle">{{result.confirmed ? '您可凭取件码稍后取件' : '请妥善保存取件码'}}</text>
    </view>

    <view class="code-panel">
      <text class="code-label">6 位取件码</text>
      <text class="code-value">{{result.pickupCode}}</text>
    </view>

    <view class="inline-row">
      <text>预留手机号</text>
      <text>{{result.maskedPhone}}</text>
    </view>
    <view class="inline-row">
      <text>柜体编号</text>
      <text>{{result.cabinetNo}}</text>
    </view>
    <view class="inline-row">
      <text>生成时间</text>
      <text>{{result.createdAtText}}</text>
    </view>

    <text class="helper-text">{{result.instruction}}</text>
    <text class="helper-text">{{result.relayText}}</text>

    <view wx:if="{{!result.confirmed}}" class="btn-stack">
      <button class="secondary-btn" bindtap="confirmStore" loading="{{confirmingStore}}" disabled="{{confirmingStore}}">确认已关闭柜门</button>
      <button class="ghost-btn" bindtap="goHome">返回首页</button>
    </view>

    <view wx:else class="btn-stack">
      <button class="primary-btn" bindtap="goHome">返回首页</button>
      <button class="ghost-btn" bindtap="goTakePage">前往取件查询</button>
    </view>
  </view>
</view>
